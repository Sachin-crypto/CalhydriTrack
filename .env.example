# Copy this file to .env before deploying.
# Hostinger Docker Compose reads values from this file.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=caloriepostgres
POSTGRES_DB=calorie_tracker

# Required for backend auth
JWT_SECRET=calorietracker

# Public frontend URL (for backend CORS)
# Use your Hostinger domain (HTTPS recommended).
FRONTEND_URL=http://2minutesappserver.tech:3000

# Public backend API URL used by browser
# If you expose backend on port 5000 directly:
NEXT_PUBLIC_API_URL=http://2minutesappserver.tech:5000/api
# Or if proxied via domain:
# NEXT_PUBLIC_API_URL=https://api.your-domain.com/api
